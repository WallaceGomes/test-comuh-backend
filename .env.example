# Database
POSTGRES_USER=community
POSTGRES_PASSWORD=community
POSTGRES_DB=community
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://community:community@postgres:5432/community

# Host user mapping for Docker bind mounts (avoid root-owned files)
LOCAL_UID=1000
LOCAL_GID=1000

# Frontend -> API
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
FRONTEND_ALLOWED_ORIGINS=http://localhost:3001
CORS_ALLOW_VERCEL_PREVIEWS=false
CORS_VERCEL_PROJECT_SLUG=

# AWS Comprehend
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=